# Copy this file to `.env` and replace placeholders with your real secrets.
# Do NOT commit your `.env` file — `.env` is already ignored by `.gitignore`.

PIHU_ENV=production
PIHU_DEMO_MODE=0

NVIDIA_NIM_API_KEY=REPLACE_WITH_YOUR_KEY
GROQ_API_KEY=REPLACE_WITH_YOUR_KEY
GROQ_MODEL=llama-3.1-8b-instant
E2B_API_KEY=

PIHU_RESPONSE_LANGUAGE=hinglish

JWT_SECRET_KEY=replace-with-a-long-random-secret
PIHU_ADMIN_EMAIL=admin@example.com
# SHA-256 hash of the admin password, not the plaintext password.
# PowerShell: [System.BitConverter]::ToString([System.Security.Cryptography.SHA256]::Create().ComputeHash([Text.Encoding]::UTF8.GetBytes("your-password"))).Replace("-", "").ToLower()
PIHU_ADMIN_PASSWORD_SHA256=replace-with-sha256-hash
PIHU_ADMIN_ORG_ID=org_default

POSTGRES_PASSWORD=replace-with-strong-db-password
DB_ENCRYPTION_KEY=replace-with-fernet-key
REDIS_URL=redis://redis:6379/0
DATABASE_URL=postgresql+asyncpg://pihu_user:replace-with-strong-db-password@postgres:5432/pihu_saas

CORS_ALLOWED_ORIGINS=http://localhost:5173
GRAFANA_ADMIN_PASSWORD=replace-with-strong-grafana-password

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
