# Pihu Agent — Professional Gitignore
# -----------------------------------------------------------------------------

# Runtime Data
data/
data/memory/
data/logs/
*.log
*.txt
*.json
!package.json
!taskweaver_config.json

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.env

# Workspace / IDE
.vscode/
.idea/
.DS_Store

# Third Party
third_party/taskweaver/project/temp/
third_party/taskweaver/project/logs/
third_party/TTS/
third_party/TTS_master.zip
*.zip
node_modules/
package-lock.json

# Large Data Files
*.csv

# Generated / Cache
.opencode/
.pytest_cache/

# Media / Artifacts
assets/
Gemini_Generated_Image_*.png
grid_preview.jpg
models/
*.gguf
.pihu/
.sixth/
\n+# Ignore large model, TTS and cache artifacts
data/tts_models/
.cache/
huggingface/
models/**/*.gguf
node_modules/
